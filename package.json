{
  "name": "gitlab-release-train",
  "version": "1.0.4",
  "description": "Lightweight GitLab MR release train runner for dependent Angular libraries and apps.",
  "type": "module",
  "bin": {
    "gitlab-mr-train": "./dist/cli.js",
    "gitlab-release-train": "./dist/cli.js",
    "mr-train": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "tsx test/self-check.ts",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "gitlab",
    "release",
    "cli",
    "angular"
  ],
  "author": "Sabik Abtahee",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "execa": "^9.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
