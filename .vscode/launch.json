{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "CLI: help",
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
        "args": ["${workspaceFolder}/src/cli.ts", "help"],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
      },
      {
        "type": "node",
        "request": "launch",
        "name": "CLI: dry-run train",
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
        "args": [
          "${workspaceFolder}/src/cli.ts",
          "run",
          "examples/libA-libB-appA.yaml",
          "--train",
          "dev-test"
        ],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
      }
    ]
  }